CREATE OR REPLACE PROCEDURE "GADMIN"."SP_FIN_ACC_ROW_ID"
(
    IN IN_DATE VARCHAR(10)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN
         --DATA SELECT
		DECLARE CURSOR_ROWID CURSOR WITH RETURN FOR
        SELECT COALESCE(MAX(ROW_ID),0) + 1  AS ACC_NO
           FROM GADMIN.ACCOU1;--
	    OPEN CURSOR_ROWID;--
    END P1;--
END MAIN 