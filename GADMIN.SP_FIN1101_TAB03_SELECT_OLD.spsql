--   감가상각충당금(건물)  1220300
    UPDATE SESSION.TEMP
        SET CU_TOT = (SELECT SUM(CU_AMT) FROM SESSION.TEMP WHERE ACC_CD IN ('1220200','1220300') ),
             BE_TOT = (SELECT SUM(BE_AMT) FROM SESSION.TEMP WHERE ACC_CD IN ('1220200','1220300') )
      WHERE ACC_CD = '1220300';--

