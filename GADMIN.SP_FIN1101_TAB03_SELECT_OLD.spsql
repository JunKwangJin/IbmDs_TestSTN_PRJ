                   AND A.ACC_CD = B.ACC_CD
                   AND B.ACC_GB = '자산'
                   AND B.CHULRYEOK_CD LIKE '121%'  --ACC_CD와 CHULRYEOK_CD가 달라 ACC_CD를 사용못함(집계도 틀림)
                   AND DATE BETWEEN IN_FROMDATE AND IN_TODATE
