CREATE OR REPLACE PROCEDURE "GADMIN"."SP_FIN1601_TAB01_PRINT"
(
    IN IN_USER_ID VARCHAR(25)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN

		DECLARE CURSOR_ACC CURSOR WITH RETURN FOR
		SELECT *
          FROM GADMIN.BSACC2
         ORDER BY ACC_CD;--
	OPEN CURSOR_ACC;--
   END P1;--
END MAIN 