CREATE OR REPLACE PROCEDURE "GADMIN"."SP_SUIPKUM_SELECT"
(
    IN IN_DATE VARCHAR(10)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN
         --DATA SELECT
		DECLARE CURSOR_SUIP CURSOR WITH RETURN FOR
        SELECT SUM(IPGUMSIL) AS TOTAL
           FROM  SUIBSMAR
          WHERE DATE = IN_DATE;--
	    OPEN CURSOR_SUIP;--
    END P1;--
END MAIN 