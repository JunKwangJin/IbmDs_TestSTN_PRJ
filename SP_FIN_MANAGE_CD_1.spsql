CREATE OR REPLACE PROCEDURE "GADMIN"."SP_FIN_MANAGE_CD_1"
(IN IN_USER_ID VARCHAR(25))
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN
		DECLARE CURSOR_BSACC7 CURSOR WITH RETURN FOR
        SELECT *
           FROM GADMIN.BSACC7
          ;--
	    OPEN CURSOR_BSACC7;--
    END P1;--
END MAIN 