CREATE OR REPLACE PROCEDURE "GADMIN"."SP_COMPANY_NAME"
(
    IN IN_USER_ID VARCHAR(25)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN
		DECLARE CURSOR_COMPANY_NAME CURSOR WITH RETURN FOR
        SELECT SOSOK_NM
           FROM GADMIN.EBUS_sosok_m
          WHERE sosok_cd='00000';--
	    OPEN CURSOR_COMPANY_NAME;--
    END P1;--
END MAIN 