CREATE OR REPLACE PROCEDURE "GADMIN"."SP_JAGUMA1_ROW_ID_MAX"
(
    IN IN_USER_ID VARCHAR(25)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN
         --DATA SELECT
		DECLARE CURSOR_TODAY CURSOR WITH RETURN FOR
        SELECT MAX(ROW_ID) + 1 FROM JAGUMA1;--
	    OPEN CURSOR_TODAY;--
    END P1;--
END MAIN 