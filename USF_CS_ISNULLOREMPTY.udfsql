CREATE FUNCTION "GADMIN"."USF_CS_ISNULLOREMPTY"  ( INSTR VARCHAR(4000) )

  RETURNS BOOLEAN --VARCHAR(4000)

  DETERMINISTIC NO EXTERNAL ACTION

  CONTAINS SQL

  BEGIN  --A 
----
----   문자열이 null 이거나 ''(문자열이 크기가 0인) 인 경우 FALSE를 전달한다.
----

	IF INSTR IS NULL OR INSTR = '' THEN 
      RETURN TRUE;
  END IF;

  RETURN TRUE;--  REVSTR;--  D 

END  --A