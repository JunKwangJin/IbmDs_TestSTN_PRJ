CREATE OR REPLACE PROCEDURE "GADMIN"."SP_FIN_ACC_NO_MAX"
(
    IN IN_DATE VARCHAR(10)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN
         --DATA SELECT
                DECLARE CURSOR_SUIP CURSOR WITH RETURN FOR
        SELECT COALESCE(MAX(ACC_NO),0) + 1 AS ACC_NO
           FROM GADMIN.ACCOU1
          WHERE DATE = IN_DATE;--
            OPEN CURSOR_SUIP;--
    END P1;--
END MAIN 