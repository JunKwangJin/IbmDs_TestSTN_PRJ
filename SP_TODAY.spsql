CREATE OR REPLACE PROCEDURE "GADMIN"."SP_TODAY"
(
    IN IN_DATE VARCHAR(10)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN
         --DATA SELECT
		DECLARE CURSOR_TODAY CURSOR WITH RETURN FOR
        select  VARCHAR_FORMAT(CURRENT TIMESTAMP, 'YYYY-MM-DD HH24:MI:SS') from SYSIBM.SYSDUMMY1;--
	    OPEN CURSOR_TODAY;--
    END P1;--
END MAIN 