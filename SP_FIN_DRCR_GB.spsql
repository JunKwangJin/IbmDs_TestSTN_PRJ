CREATE OR REPLACE PROCEDURE "GADMIN"."SP_FIN_DRCR_GB"
(
    IN IN_USER_ID VARCHAR(25)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN
		DECLARE CURSOR_DRCR_GB CURSOR WITH RETURN FOR
        SELECT CD, CD_NM
           FROM GADMIN.EBUS_COMMON_C
          WHERE UP_CD = 'FIN04';--
	    OPEN CURSOR_DRCR_GB;--
    END P1;--
END MAIN 