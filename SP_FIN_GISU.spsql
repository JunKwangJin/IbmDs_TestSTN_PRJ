CREATE OR REPLACE PROCEDURE "GADMIN"."SP_FIN_GISU"
(
    IN IN_FROMDATE VARCHAR(10), IN IN_TODATE VARCHAR(10), IN IN_USER_ID VARCHAR(25)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN
		DECLARE CURSOR_GISU CURSOR WITH RETURN FOR
        SELECT GISU
           FROM GADMIN.BSACC9
          WHERE START <= IN_FROMDATE
            AND TERMINATION >= IN_TODATE;--
	    OPEN CURSOR_GISU;--
    END P1;--
END MAIN 