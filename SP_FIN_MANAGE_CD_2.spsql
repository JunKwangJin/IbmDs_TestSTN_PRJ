CREATE OR REPLACE PROCEDURE "GADMIN"."SP_FIN_MANAGE_CD_2"
(
    IN IN_MANAGE_CD VARCHAR(10)
  , IN IN_USER_ID  VARCHAR(25)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN
		DECLARE CURSOR_BSACC8 CURSOR WITH RETURN FOR
        SELECT DETAIL_CD, DETAIL_ITEM
           FROM GADMIN.BSACC8
          WHERE MANAGE_CD = IN_MANAGE_CD;--
	    OPEN CURSOR_BSACC8;--
    END P1;--
END MAIN 