--                                                                , 0 AS CHUL_QTY
--                                                                , 0 AS CHUL_AMT
--                                                                , 0 AS EDONG_QTY -- 업무를 몰라서 일단 0로 셋팅
--                                                                , 0 AS EDONG_AMT
--                                                          FROM GADMIN.JACHUL2
--                                                        WHERE 1 = 1
--                                                         AND DATE BETWEEN IN_EWOL_FROMDATE AND IN_EWOL_TODATE
--                                                        GROUP BY CHANGGO
--                                                ) A
--                                        GROUP BY CHANGGO
--                                    ) A
--                            UNION ALL
--                            SELECT CHANGGO
--                                    , 0 AS EWOL_QTY
--                                    , 0 AS EWOL_PRICE
--                                    , SUM(CASE GUBUN WHEN '반품'THEN QTY * -1 ELSE  QTY END) AS GU_QTY
--                                    , SUM(CASE GUBUN WHEN '반품'THEN SUPPLY_PRICE * -1 ELSE SUPPLY_PRICE END ) AS GU_AMT
--                                    , 0 AS CHUL_QTY
--                                    , 0 AS CHUL_AMT
--                                    , 0 AS EDONG_QTY
--                                    , 0 AS EDONG_AMT
--                            FROM GADMIN.JAGUMA1
--                            WHERE 1 = 1
--                             AND DATE = IN_DATE
--                            GROUP BY CHANGGO
--                            UNION ALL
--                            SELECT CHANGGO
--                                    , 0 AS EWOL_QTY
--                                    , 0 AS EWOL_PRICE
--                                    , 0 AS GU_QTY
--                                    , 0 AS GU_AMT
--                                    , SUM(CASE GUBUN WHEN '취소' THEN QTY * -1 ELSE QTY END ) AS CHUL_QTY
--                                    , SUM(CASE GUBUN WHEN '취소' THEN PRICE * -1 ELSE PRICE END ) AS CHUL_AMT
--                                   , 0 AS EDONG_QTY
--                                    , 0 AS EDONG_AMT
--                              FROM GADMIN.JACHUL1
--                            WHERE 1 = 1
--                             AND DATE = IN_DATE
--                            GROUP BY CHANGGO
--                            UNION ALL
--                            SELECT CHANGGO
--                                    , 0 AS EWOL_QTY
--                                    , 0 AS EWOL_PRICE
--                                    , 0 AS GU_QTY
--                                    , 0 AS GU_AMT
--                                    , 0 AS CHUL_QTY
--                                    , 0 AS CHUL_AMT
--                                    , 0 AS EDONG_QTY -- 업무를 몰라서 일단 0로 셋팅
--                                    , 0 AS EDONG_AMT
--                              FROM GADMIN.JACHUL2
--                            WHERE 1 = 1
--                             AND DATE = IN_DATE
--                            GROUP BY CHANGGO
--                        ) A
                )
        ORDER BY 1
       ;--

	    OPEN CURSOR_MAT;--
    END P1;--

END MAIN 