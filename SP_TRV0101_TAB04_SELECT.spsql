CREATE OR REPLACE PROCEDURE "GADMIN"."SP_TRV0101_TAB04_SELECT"
( IN IN_EVENT_NO VARCHAR(21)
, IN IN_USER_ID VARCHAR(25)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN
    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--

    P1: BEGIN

		DECLARE CURSOR_TRV CURSOR WITH RETURN FOR
        SELECT EVENT_NO, PICTURE, SCAN, VIDEO
          FROM SAGO13
         WHERE 1 = 1
            AND EVENT_NO LIKE IN_EVENT_NO
         ;--
	    OPEN CURSOR_TRV;--
    END P1;--

END MAIN 