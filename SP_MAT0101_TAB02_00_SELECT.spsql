CREATE OR REPLACE PROCEDURE "GADMIN"."SP_MAT0101_TAB02_00_SELECT"
( IN IN_FROMDATE    VARCHAR(10)
, IN IN_TODATE      VARCHAR(10)
, IN IN_FROMPROD_NO VARCHAR(8)
, IN IN_TOPROD_NO   VARCHAR(8)
, IN IN_SANGHO_CD   VARCHAR(5)
, IN IN_PROD_NM     VARCHAR(60)
, IN IN_SPEC        VARCHAR(30)
, IN IN_CASHGB      VARCHAR(6)
, IN IN_CLASSGB     VARCHAR(30)
, IN IN_JAJAGB      VARCHAR(15)
, IN IN_LISTGB      VARCHAR(1) -- 1:업체리스트, 2: 자재구매리스트
, IN IN_USER_ID     VARCHAR(25)
)
/*******************************************************************************
파일명	: GADMIN.SP_DRV0103_S01
생성일자	: 2020.08.01
생성자	: 이재열
내용	    : 운행계통 조회 입니다.
USAGE   : GADMIN.SP_MAT0101_TAB02_00_SELECT(시잗일자, 종료일자,시작자재번호, 종료자재번호, 상호코드, 자재명, 규격, 현금구분, 자재분류구분, USER ID)
수정일자	: 2021.07.01
수정자	: 전광진
수정내용	: 자재구매 내역 리스트, 거래처 리스트를 통합하고  조회조건을 추가 함
INPUT	: IN_USER_ID        1.사용자 ID
	    : IN_PYEON_GB	    2.코드명

OUTPUT	: OUT_CNT	    	A.처리COUNT
	    : OUT_MSG	        B.처리결과메시지
*******************************************************************************/

  DYNAMIC RESULT SETS 1
  LANGUAGE SQL
MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--

    P1: BEGIN
         --DATA SELECT
        DECLARE V_QUERY_STRING CLOB;--
        DECLARE V_QUERY_WHERE VARCHAR(200);--
        DECLARE V_QUERY_TABLE VARCHAR(200);--
        DECLARE V_LENGTH INTEGER;--
        DECLARE CURSOR_MAT CURSOR WITH RETURN TO CLIENT FOR S1;--

        SET IN_FROMDATE    = COALESCE(IN_FROMDATE   , '');--
        SET IN_TODATE      = COALESCE(IN_TODATE     , '');--
        SET IN_FROMPROD_NO = COALESCE(IN_FROMPROD_NO, '');--
        SET IN_TOPROD_NO   = COALESCE(IN_TOPROD_NO  , '');--
        SET IN_SANGHO_CD   = COALESCE(IN_SANGHO_CD  , '');--
        SET IN_PROD_NM     = COALESCE(IN_PROD_NM    , '');--
        SET IN_SPEC        = COALESCE(IN_SPEC       , '');--
        SET IN_CASHGB      = COALESCE(IN_CASHGB     , '');--
        SET IN_CLASSGB     = COALESCE(IN_CLASSGB    , '');--
        SET IN_JAJAGB      = COALESCE(IN_JAJAGB     , '');--

        IF IN_LISTGB = '1' THEN
           SET V_QUERY_STRING =
             'SELECT A.SANGHO_CD, A.SANGHO, SUM(A.QTY) AS QTY, SUM(A.SUPPLY_PRICE) AS SUPPLY_PRICE, COUNT(*) AS CNT, MAX(A.CHANGGO) AS CHANGGO, '||''''||' AS BIGO';--
         ELSEIF IN_LISTGB = '2' THEN
           SET V_QUERY_STRING =
             'SELECT A.DATE, A.CHANGGO, A.SANGHO, CASH_GB, A.PRODUC_NO, A.PRODUC_NM, A.UNIT, A.QTY, A.UNIT_PRICE, A.SUPPLY_PRICE';--
         ELSE SET V_QUERY_STRING = '';--
        END IF;--




        SET V_QUERY_STRING = V_QUERY_STRING ||
             '  FROM GADMIN.JAGUMA1 A
                LEFT OUTER JOIN GADMIN.BSJAJA B ON (A.PRODUC_NO = B.PRODUC_NO)
                LEFT OUTER JOIN GADMIN.BSTRADE C ON (A.SANGHO_CD = C.SANGHO_CD)';--

        SET V_QUERY_STRING = V_QUERY_STRING || ' WHERE DATE      BETWEEN '''|| IN_FROMDATE ||''' AND '''||IN_TODATE ||'''';--
        IF IN_FROMPROD_NO > '' OR IN_TOPROD_NO > '' THEN
             SET V_QUERY_STRING =  V_QUERY_STRING || '  AND PRODUC_NO BETWEEN '''|| IN_FROMPROD_NO ||''' AND '''||IN_TOPROD_NO||'''';--
        END IF;--
        IF IN_SANGHO_CD   > '' THEN
             SET V_QUERY_STRING =  V_QUERY_STRING || '  AND SANGHO_CD = '''|| IN_SANGHO_CD ||'''';--
        END IF;--
        IF IN_PROD_NM     > '' THEN
             SET V_QUERY_STRING =  V_QUERY_STRING || '  AND PRODUC_NM LIKE ''%'||IN_PROD_NM ||'''';--
        END IF;--
        IF IN_FROMPROD_NO > '' THEN
             SET V_QUERY_STRING =  V_QUERY_STRING || '  AND SPEC LIKE ''%'||IN_SPEC ||'''';--
        END IF;--
        IF IN_FROMPROD_NO > '' THEN
             SET V_QUERY_STRING =  V_QUERY_STRING || '  AND CASH_GB   = '''|| IN_CASHGB ||'''';--
        END IF;--
        IF IN_FROMPROD_NO > '' THEN
             SET V_QUERY_STRING =  V_QUERY_STRING || '  AND B.CLASS     = '''|| IN_CASHGB ||'''';--
         END IF;--
        IF IN_FROMPROD_NO > '' THEN
             SET V_QUERY_STRING =  V_QUERY_STRING || '  AND B.JAJA_GB   = '''|| IN_CASHGB ||'''';--
        END IF;--

/*
        IF IN_LISTGB = '1' THEN
           SET V_QUERY_STRING =
             'SELECT A.SANGHO_CD, A.SANGHO, SUM(A.QTY) AS QTY, SUM(A.SUPPLY_PRICE) AS SUPPLY_PRICE, COUNT(*) AS CNT, MAX(A.CHANGGO) AS CHANGGO, '||''''||' AS BIGO' ||
--             CHR(13) || V_QUERY_TABLE ||
             CHR(13) || V_QUERY_WHERE ||
             CHR(13) || ' GROUP BY A.SANGHO_CD, A.SANGHO' ||
             CHR(13) || ' ORDER BY A.SANGHO_CD, A.SANGHO';--
         ELSEIF IN_LISTGB = '2' THEN
           SET V_QUERY_STRING =
             'SELECT A.DATE, A.CHANGGO, A.SANGHO, CASH_GB, A.PRODUC_NO, A.PRODUC_NM, A.UNIT, A.QTY, A.UNIT_PRICE, A.SUPPLY_PRICE'||
--             CHR(13) || V_QUERY_TABLE ||
             CHR(13) || V_QUERY_WHERE ||
             CHR(13) || 'ORDER BY A.SANGHO_CD, A.SANGHO';--
         ELSE SET V_QUERY_STRING = '';--
        END IF;--
*/
        IF IN_LISTGB = '1' THEN
           SET V_QUERY_STRING =
             V_QUERY_STRING ||
             CHR(13) || ' GROUP BY A.SANGHO_CD, A.SANGHO' ||
             CHR(13) || ' ORDER BY A.SANGHO_CD, A.SANGHO';--
         ELSEIF IN_LISTGB = '2' THEN
           SET V_QUERY_STRING =
             V_QUERY_STRING ||
             CHR(13) || 'ORDER BY A.SANGHO_CD, A.SANGHO';--
         ELSE SET V_QUERY_STRING = '';--
        END IF;--
        SET V_QUERY_STRING = '';--
        SET V_LENGTH = LENGTH(V_QUERY_STRING);--
	    PREPARE S1 FROM V_QUERY_STRING;	 --
	    OPEN CURSOR_MAT;--
    END P1;--

END MAIN 