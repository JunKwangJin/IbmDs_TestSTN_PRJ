CREATE OR REPLACE PROCEDURE "GADMIN"."SP_TRV0101_LEFT_SELECT_TEST"
DYNAMIC RESULT SETS 1
LANGUAGE SQL MAIN:
BEGIN
   DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--


DECLARE SQLCODE INTEGER DEFAULT 0;--


P1:
BEGIN
   --DATA SELECT
DECLARE CURSOR_SAGO1 CURSOR WITH RETURN FOR
SELECT
   EVENT_NO,
   TO_CHAR(SAGO1.EVENT_DT,
   'YYYY.MM.DD') AS EVENT_DT,
   SAGO1.CAR_NO,
   COALESCE(BSDRIVE.FULLNAME,
   SAGO1.DRIVER) AS DRIVER
FROM    GADMIN.SAGO1
LEFT OUTER JOIN GADMIN.BSDRIVE ON
   SAGO1.SABUN = BSDRIVE.SABUN
ORDER BY
   SAGO1.EVENT_DT,
   SAGO1.CAR_NO,
   BSDRIVE.FULLNAME;--


OPEN CURSOR_SAGO1;--

END P1;--

END MAIN 