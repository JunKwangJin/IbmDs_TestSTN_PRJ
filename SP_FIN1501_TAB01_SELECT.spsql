CREATE OR REPLACE PROCEDURE "GADMIN"."SP_FIN1501_TAB01_SELECT"
(
    IN IN_GISU VARCHAR(3),
    IN IN_USER_ID VARCHAR(25)
)
  DYNAMIC RESULT SETS 1
  LANGUAGE SQL

MAIN: BEGIN

    DECLARE SQLSTATE CHAR(5) DEFAULT '00000';--
    P1: BEGIN

		DECLARE CURSOR_HAPJAN CURSOR WITH RETURN FOR
		SELECT *
          FROM GADMIN.HAPJAN
         WHERE YEAR = IN_GISU
         ORDER BY ACC_CD;--
	OPEN CURSOR_HAPJAN;--
   END P1;--
END MAIN 